{
  "extends": "./node_modules/gts/tsconfig-google.json",
  "ts-node": {
    "require": ["tsconfig-paths/register"]
  },
  "compilerOptions": {
    "baseUrl": "src",
    "target": "es2022",
    "lib": ["es2022"],
    "moduleResolution": "node",
    "module": "commonjs",
    "outDir": "build",
    "sourceMap": true,
    "esModuleInterop": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "strict": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["src"]
}
